{
  "manifest_version": 3,
  "name": "UI Commander",
  "version": "0.1.12",
  "key": "",
  "description": "Capture frontend bug reproductions in the current Chrome session.",
  "permissions": [
    "activeTab",
    "debugger",
    "nativeMessaging",
    "offscreen",
    "scripting",
    "storage",
    "tabs"
  ],
  "minimum_chrome_version": "116",
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "UI Commander"
  },
  "commands": {
    "start-recording": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Start the current UI Commander session"
    },
    "stop-recording": {
      "suggested_key": {
        "default": "Alt+E",
        "mac": "Alt+E"
      },
      "description": "Stop the current UI Commander session"
    }
  }
}
